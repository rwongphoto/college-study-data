# Copy to .env and fill in the value. .env is gitignored.
#
# Get a free key at https://api.data.gov/signup/ — used to fill the
# 2011-2024 institution-level Scorecard history gap that the bulk archive
# doesn't cover. Rate limit: 1,000 requests/IP/hour.
COLLEGE_SCORECARD_API_KEY=your_api_data_gov_key_here

# Secrets — never commit
.env
.env.local
.env.*.local
*.pem
*.key

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/*.tsbuildinfo
# Symlinks created by scripts/prebuild.mjs to expose published JSON as CDN assets
frontend/public/data/
# Program XML sitemaps + index, regenerated each build by scripts/prebuild.mjs
# from the data/published/sitemap/ shards (which ARE committed).
frontend/public/sitemaps/
frontend/public/sitemap-index.xml

# Build-time manifest of state/city/institution slugs (regenerated each build)
data/published/_manifest.json

# Raw data caches — large, regenerate via pipeline
data/raw/

# Published outputs are committed (they ARE the build target). Comment out
# the next line if you decide to rebuild fresh per CI run instead.
# data/published/

# Editor + OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/
